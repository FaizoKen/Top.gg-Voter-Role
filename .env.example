# Server
HOST=0.0.0.0
PORT=3000

# Top.gg Webhook
TOPGG_WEBHOOK_SECRET=whs_your_secret_here
TOPGG_PROJECT_ID=          # optional: filter by project id or platform_id (any unique snowflake)

# RoleLogic API
ROLELOGIC_TOKEN=rl_your_token_here
ROLELOGIC_GUILD_ID=123456789012345678
ROLELOGIC_ROLE_ID=123456789012345678

# Tuning
SYNC_INTERVAL_SECS=60      # how often to push voter list to RoleLogic
VOTE_TTL_SECS=86400         # 24 hours
